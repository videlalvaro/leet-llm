#include <metal_stdlib>
using namespace metal;
constant uint keyTileSize = 16; constant uint maxHead = 128; constant uint groupWidth = 128;
kernel void tiled_fused_attention(device const float *q [[buffer(0)]], device const float *k [[buffer(1)]], device const float *v [[buffer(2)]], device float *o [[buffer(3)]], constant uint4 &shape [[buffer(4)]], constant uint4 &dims [[buffer(5)]], uint local [[thread_index_in_threadgroup]], uint group [[threadgroup_position_in_grid]]) {
    if (group >= shape.x * shape.z) return; uint query = group / shape.z, qHead = group % shape.z, kvHead = qHead / dims.y, queryPosition = dims.z + query; threadgroup float scores[keyTileSize], weights[keyTileSize], accumulator[maxHead], state[3]; for (uint d = local; d < dims.x; d += groupWidth) accumulator[d] = 0.0f; if (local == 0) { state[0] = -INFINITY; state[1] = 0.0f; state[2] = 0.0f; } threadgroup_barrier(mem_flags::mem_threadgroup);
    for (uint tileStart = 0; tileStart < shape.y; tileStart += keyTileSize) { if (local < keyTileSize) { uint key = tileStart + local; float score = -INFINITY; if (key < shape.y && dims.w + key <= queryPosition) { score = 0.0f; for (uint d = 0; d < dims.x; ++d) score += q[(query * shape.z + qHead) * dims.x + d] * k[(key * shape.w + kvHead) * dims.x + d]; score *= rsqrt(float(dims.x)); } scores[local] = score; } threadgroup_barrier(mem_flags::mem_threadgroup); if (local == 0) { float tileMax = -INFINITY; for (uint j = 0; j < keyTileSize; ++j) tileMax = max(tileMax, scores[j]); float newMax = max(state[0], tileMax); float alpha = isfinite(state[0]) ? exp(state[0] - newMax) : 0.0f; float tileSum = 0.0f; for (uint j = 0; j < keyTileSize; ++j) { weights[j] = isfinite(scores[j]) ? exp(scores[j] - newMax) : 0.0f; tileSum += weights[j]; } state[1] = state[1] * alpha + tileSum; state[0] = newMax; state[2] = alpha; } threadgroup_barrier(mem_flags::mem_threadgroup); for (uint d = local; d < dims.x; d += groupWidth) { float sum = accumulator[d] * state[2]; for (uint j = 0; j < keyTileSize; ++j) { uint key = tileStart + j; if (key < shape.y) sum += weights[j] * v[(key * shape.w + kvHead) * dims.x + d]; } accumulator[d] = sum; } threadgroup_barrier(mem_flags::mem_threadgroup); }
    for (uint d = local; d < dims.x; d += groupWidth) o[(query * shape.z + qHead) * dims.x + d] = accumulator[d] / state[1];
}